# .secrets.example — KEY=VALUE 형식. 실제 키는 .secrets 에 작성 (이 파일은 git 추적용 템플릿).

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Kakao Alimtalk (Solapi) — 천명당 매일 운세 발송용 ───
# 1) https://console.solapi.com 가입 → API 키 발급
# 2) 카카오 비즈니스 채널 @cheonmyeongdang (월렛 ID 908652) 연동 토큰 신청
# 3) 알림톡 템플릿 카카오 비즈센터에서 등록·승인 → templateCode 받기
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=
KAKAO_PF_ID=908652
KAKAO_TEMPLATE_DAILY_FORTUNE=

# ─── Gumroad ───
GUMROAD_ACCESS_TOKEN=

# ─── Google Analytics 4 (Data API v1beta) ───
# Property ID 는 GA4 관리 > 속성 설정 에서 확인 (숫자만, 예: 123456789)
# 서비스 계정 JSON: GCP 콘솔 > 서비스 계정 생성 > JSON 다운 → GA4 속성에 뷰어 권한 부여
GA4_PROPERTY_ID_TAX=
GA4_PROPERTY_ID_KORLENS=
GA4_PROPERTY_ID_CMD=
GA4_SERVICE_ACCOUNT_JSON=C:\Users\hdh02\Desktop\cheonmyeongdang\.secrets\ga4-service-account.json

# ─── Vercel Analytics ───
# 토큰: https://vercel.com/account/tokens (Read scope 면 충분)
# 팀 계정이면 VERCEL_TEAM_ID 도 필요. 개인 계정이면 비워두기.
# ⚠️ Web Analytics PV/UV 는 공식 REST API 미지원 (2026-04 기준).
#    이 모듈은 배포 통계만 자동 수집. PV/UV 는 Drain JSON 경로 지정 시 채워짐.
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_IDS=tax-n-benefit-api,korlens,cheonmyeongdang.com
# 선택: Vercel Drain 으로 적재한 분석 JSON (없으면 PV/UV placeholder)
VERCEL_ANALYTICS_DRAIN_PATH=
