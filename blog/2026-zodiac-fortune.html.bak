*{box-sizing:border-box;margin:0;padding:0}
html,body{background:var(--bg);color:var(--text);font-family:'Noto Sans KR','Pretendard',-apple-system,BlinkMacSystemFont,sans-serif;line-height:1.8;font-size:16px;-webkit-text-size-adjust:100%}
