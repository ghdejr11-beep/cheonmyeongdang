# ============================================
# 천명당 그룹 환경변수 템플릿
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값 채우기
# ⚠️  .env 는 절대 git에 커밋하지 말 것 (.gitignore에 등록됨)
# ============================================

# ─────────────────────────────────────
# 🏢 본사 (HQ) — 텔레그램 봇 (일일 보고용)
# ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# @userinfobot 에 /start 하면 chat id 받을 수 있음

# ─────────────────────────────────────
# 📺 미디어팀 / 📚 전자책 / 🔮 천명당 — 공용 영상·이미지
# fal.ai: Runway, Veo, Kling, Pika, Luma, FLUX 통합 API
# 가입: https://fal.ai
# ─────────────────────────────────────
FAL_API_KEY=

# ─────────────────────────────────────
# 📺 미디어팀 — HeyGen (한국어 AI 아바타·더빙)
# 가입: https://heygen.com
# ─────────────────────────────────────
HEYGEN_API_KEY=

# ─────────────────────────────────────
# 📺 미디어팀 — YouTube Data API v3
# 발급: https://console.cloud.google.com (OAuth 2.0 Client)
# ─────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ─────────────────────────────────────
# 📚 전자책팀 — Amazon KDP 계정 (판매는 수동 업로드)
# API는 없고, 이메일만 기록 (로그용)
# ─────────────────────────────────────
AMAZON_KDP_EMAIL=

# ─────────────────────────────────────
# 🛡️ 보험다보여 — 금감원·복지부 API (심사 후 발급)
# ─────────────────────────────────────
FSS_INSTITUTION_CODE=
FSS_API_KEY=
MYHEALTHWAY_API_KEY=

# ─────────────────────────────────────
# 💰 결제 (글로벌 부서 공용)
# ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ─────────────────────────────────────
# 💰 결제 (한국)
# ─────────────────────────────────────
TOSS_SECRET_KEY=
KAKAOPAY_CID=
