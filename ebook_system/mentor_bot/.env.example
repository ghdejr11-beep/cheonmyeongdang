# 로컬 테스트용. 실제 배포는 Render.com 대시보드에서 설정.

# Anthropic API 키 (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Gumroad 상품 ID (Gumroad 대시보드 → 상품 → Product ID 에서 확인)
# 반드시 PREMIUM 상품의 ID 여야 함
GUMROAD_PRODUCT_ID=your_premium_product_id

# 세션 쿠키 서명용 (무작위 긴 문자열)
SESSION_SECRET=generate-a-long-random-string-here

# 사용할 모델 (비용 절감하려면 haiku)
MENTOR_MODEL=claude-haiku-4-5
